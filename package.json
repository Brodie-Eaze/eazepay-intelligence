{
  "name": "eazepay-intelligence",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "EazePay Intelligence — the data warehouse for every business in the EazePay group. HighSale credit data, lender outcomes, MiCamp processing, Pixie usage. Read-only by design.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@<3.1.2": "^3.1.2"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-c4j6-fc7j-m34r",
        "GHSA-36qx-fr4f-26g5",
        "GHSA-h25m-26qc-wcjf",
        "GHSA-q4gf-8mx6-v5v3",
        "GHSA-8h8q-6873-q5fj",
        "GHSA-jx2c-rxcm-jvmq",
        "GHSA-q7rr-3cgh-j5r3"
      ]
    }
  }
}
