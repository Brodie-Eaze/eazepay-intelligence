  name        String
  color       String   @default("slate")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  assignments TagAssignment[]
  org         Organization    @relation("OrgTags", fields: [orgId], references: [id])

