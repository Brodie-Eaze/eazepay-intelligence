  WEBHOOK
  IN_APP
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum CaseType {
  FRAUD
  DISPUTE
  REGULATORY
  SUPPORT
  OTHER
}

// ─── API tokens (programmatic access) ──────────────────────────────────────

model ApiToken {
  id           String          @id @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  // Org this PAT can act within. PATs are pinned to one org by design;
  // a user with N memberships gets N PATs (one per org), not one PAT
  // that magically spans orgs. The bearer-auth middleware verifies the
  // PAT's orgId matches the request's resolved org.
  orgId        String          @map("org_id") @db.Uuid
  name         String
  prefix       String          @unique // visible part of the token, e.g. "epi_pk_a1b2c3d4"
  hashedSecret String          @map("hashed_secret") // SHA-256 of the secret half
  scopes       ApiTokenScope[]
  expiresAt    DateTime?       @map("expires_at") @db.Timestamptz(6)
  lastUsedAt   DateTime?       @map("last_used_at") @db.Timestamptz(6)
  revokedAt    DateTime?       @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation("OrgApiTokens", fields: [orgId], references: [id])

  @@index([userId, revokedAt])
  @@index([orgId])
  @@map("api_tokens")
}

// ─── Async exports ─────────────────────────────────────────────────────────

model Export {
  id          String       @id @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  type        ExportType
  format      ExportFormat
  filters     Json         @default("{}")
  status      ExportStatus @default(PENDING)
  rowCount    Int?         @map("row_count")
  filePath    String?      @map("file_path")
  fileBytes   Int?         @map("file_bytes")
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt   DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz(6)
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz(6)

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation("OrgExports", fields: [orgId], references: [id])

  @@index([orgId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("exports")
}

// ─── Outbound webhook subscriptions + deliveries ───────────────────────────

model WebhookSubscription {
  id          String   @id @db.Uuid
  // Phase 1 retrofit: org-scoped. dispatch() only fans events to
  // subscriptions whose orgId matches the event's orgId, preventing
  // cross-tenant data leakage via outbound webhooks (GAP-115 / HARDENING X-08).
  orgId       String   @map("org_id") @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  name        String
  url         String
  secretHash  String   @map("secret_hash") // signing key, stored hashed
  eventTypes  String[] @map("event_types")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner      User              @relation(fields: [ownerUserId], references: [id])
  org        Organization      @relation("OrgWebhookSubscriptions", fields: [orgId], references: [id])
  deliveries WebhookDelivery[]

  @@index([orgId, isActive])
  @@index([ownerUserId, isActive])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id               String                @id @db.Uuid
  orgId            String                @map("org_id") @db.Uuid
  subscriptionId   String                @map("subscription_id") @db.Uuid
  eventType        String                @map("event_type")
  payload          Json
  status           WebhookDeliveryStatus @default(PENDING)
  attemptCount     Int                   @default(0) @map("attempt_count")
  lastResponseCode Int?                  @map("last_response_code")
  lastError        String?               @map("last_error")
  scheduledFor     DateTime              @default(now()) @map("scheduled_for") @db.Timestamptz(6)
  deliveredAt      DateTime?             @map("delivered_at") @db.Timestamptz(6)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id])
  org          Organization        @relation("OrgWebhookDeliveries", fields: [orgId], references: [id])

  @@index([orgId, status, scheduledFor])
  @@index([subscriptionId, createdAt(sort: Desc)])
  @@index([status, scheduledFor])
  @@map("webhook_deliveries")
}

// ─── Notification channels + alert rules + alerts ──────────────────────────

model NotificationChannel {
  id        String      @id @db.Uuid
  orgId     String      @map("org_id") @db.Uuid
  name      String
  kind      ChannelKind
  config    Json // { url } for SLACK/WEBHOOK, { to } for EMAIL
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  alertRules       AlertRule[]
  scheduledReports ScheduledReport[] @relation("ScheduledReportChannel")
  org              Organization      @relation("OrgNotificationChannels", fields: [orgId], references: [id])

  @@index([orgId, isActive])
  @@map("notification_channels")
}

model AlertRule {
  id            String        @id @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  name          String
  description   String?
  query         Json // declarative rule (e.g. { metric: "webhook_failure_rate_24h", op: ">", value: 0.05 })
  windowMinutes Int           @default(60) @map("window_minutes")
  severity      AlertSeverity @default(WARN)
  channelId     String?       @map("channel_id") @db.Uuid
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  channel NotificationChannel? @relation(fields: [channelId], references: [id])
  alerts  Alert[]
  org     Organization         @relation("OrgAlertRules", fields: [orgId], references: [id])

  @@index([orgId, isActive])
  @@map("alert_rules")
}

model Alert {
  id             String        @id @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  ruleId         String        @map("rule_id") @db.Uuid
  state          AlertState    @default(OPEN)
  severity       AlertSeverity
  payload        Json // captured metric values + context
  firedAt        DateTime      @default(now()) @map("fired_at") @db.Timestamptz(6)
  acknowledgedAt DateTime?     @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy String?       @map("acknowledged_by") @db.Uuid
  snoozedUntil   DateTime?     @map("snoozed_until") @db.Timestamptz(6)
  resolvedAt     DateTime?     @map("resolved_at") @db.Timestamptz(6)

  rule AlertRule    @relation(fields: [ruleId], references: [id])
  org  Organization @relation("OrgAlerts", fields: [orgId], references: [id])

  @@index([orgId, firedAt(sort: Desc)])
  @@index([state, firedAt(sort: Desc)])
  @@index([ruleId, firedAt(sort: Desc)])
  @@map("alerts")
}

// ─── Portfolio (silos) ─────────────────────────────────────────────────────
// Holdco view. Each `PortfolioVertical` (coaching / medical / home-improvement
// / …) groups one or more `PortfolioBusiness` rows (the actual silos). Every
// silo has its own monthly P&L, revenue channels, product lines, unit
// economics, cohorts, and headcount snapshots — same shape across silos so
// rollups are trivially aggregable.
//
// Persistence replaces the in-memory `Map`-backed fixtures that lived in
// `portfolio.fixtures.ts`. The deterministic mock generators are still used
// by `prisma/seed-portfolio.ts` to seed demo data; runtime reads come
// straight from these tables.

enum PortfolioBusinessStatus {
  ACTIVE
  INTEGRATING
  EXITED
  PROSPECT
}

model PortfolioVertical {
  slug        String   @id
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  businesses PortfolioBusiness[]
  org        Organization        @relation("OrgPortfolioVerticals", fields: [orgId], references: [id])

  @@index([orgId])
  @@map("portfolio_verticals")
}

model PortfolioBusiness {
  slug           String                  @id
  orgId          String                  @map("org_id") @db.Uuid
  name           String
  verticalSlug   String                  @map("vertical_slug")
  status         PortfolioBusinessStatus @default(ACTIVE)
  acquiredAt     DateTime                @map("acquired_at") @db.Date
  ownershipPct   Decimal                 @map("ownership_pct") @db.Decimal(5, 4)
  hqRegion       String                  @map("hq_region")
  segment        String
  fteCount       Int                     @map("fte_count")
  // Trailing-twelve-months snapshot. Currency follows the platform default
  // (USD) unless the silo's accounting feed reports in a different ISO.
  currency       String                  @default("USD") @db.Char(3)
  ttmRevenue     Decimal                 @map("ttm_revenue") @db.Decimal(18, 2)
  ttmEbitda      Decimal                 @map("ttm_ebitda") @db.Decimal(18, 2)
  ttmGrossProfit Decimal                 @map("ttm_gross_profit") @db.Decimal(18, 2)
  arr            Decimal                 @default(0) @db.Decimal(18, 2)
  nrr            Decimal                 @db.Decimal(5, 4)
  grossMargin    Decimal                 @map("gross_margin") @db.Decimal(5, 4)
  cashOnHand     Decimal                 @map("cash_on_hand") @db.Decimal(18, 2)
  netDebt        Decimal                 @map("net_debt") @db.Decimal(18, 2)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  vertical        PortfolioVertical          @relation(fields: [verticalSlug], references: [slug])
  pnlPeriods      PortfolioFinancialPeriod[]
  revenueChannels PortfolioRevenueChannel[]
  productLines    PortfolioProductLine[]
  unitEconomics   PortfolioUnitEconomics?
  cohorts         PortfolioCohort[]
  headcount       PortfolioHeadcount[]
  org             Organization               @relation("OrgPortfolioBusinesses", fields: [orgId], references: [id])

  @@index([orgId, status])
  @@index([verticalSlug])
  @@index([status])
  @@map("portfolio_businesses")
}

model PortfolioFinancialPeriod {
  id           String   @id @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  businessSlug String   @map("business_slug")
  periodStart  DateTime @map("period_start") @db.Date
  periodLabel  String   @map("period_label")
  // Full P&L line items in reporting currency.
  revenue              Decimal @db.Decimal(18, 2)
  cogs                 Decimal @db.Decimal(18, 2)
  grossProfit          Decimal @map("gross_profit") @db.Decimal(18, 2)
  marketingSpend       Decimal @map("marketing_spend") @db.Decimal(18, 2)
  payroll              Decimal @db.Decimal(18, 2)
  rentAndUtilities     Decimal @map("rent_and_utilities") @db.Decimal(18, 2)
  softwareAndTools     Decimal @map("software_and_tools") @db.Decimal(18, 2)
  professionalServices Decimal @map("professional_services") @db.Decimal(18, 2)
  otherOpex            Decimal @map("other_opex") @db.Decimal(18, 2)
  ebitda               Decimal @db.Decimal(18, 2)
  depreciation         Decimal @db.Decimal(18, 2)
  interest             Decimal @db.Decimal(18, 2)
  tax                  Decimal @db.Decimal(18, 2)
  netIncome            Decimal @map("net_income") @db.Decimal(18, 2)
  cashIn               Decimal @map("cash_in") @db.Decimal(18, 2)
  cashOut              Decimal @map("cash_out") @db.Decimal(18, 2)
  arBalance            Decimal @map("ar_balance") @db.Decimal(18, 2)
  apBalance            Decimal @map("ap_balance") @db.Decimal(18, 2)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioFinancialPeriods", fields: [orgId], references: [id])

  @@unique([businessSlug, periodStart])
  @@index([orgId, periodStart(sort: Desc)])
  @@index([businessSlug, periodStart(sort: Desc)])
  @@map("portfolio_financial_periods")
}

model PortfolioRevenueChannel {
  id           String   @id @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  businessSlug String   @map("business_slug")
  asOf         DateTime @map("as_of") @db.Date
  channel      String
  revenue      Decimal  @db.Decimal(18, 2)
  customers    Int
  share        Decimal  @db.Decimal(5, 4)

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioRevenueChannels", fields: [orgId], references: [id])

  @@unique([businessSlug, asOf, channel])
  @@index([orgId, asOf(sort: Desc)])
  @@index([businessSlug, asOf(sort: Desc)])
  @@map("portfolio_revenue_channels")
}

model PortfolioProductLine {
  id           String   @id @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  businessSlug String   @map("business_slug")
  asOf         DateTime @map("as_of") @db.Date
  name         String
  revenue      Decimal  @db.Decimal(18, 2)
  units        Int
  avgPrice     Decimal  @map("avg_price") @db.Decimal(18, 2)

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioProductLines", fields: [orgId], references: [id])

  @@unique([businessSlug, asOf, name])
  @@index([orgId, asOf(sort: Desc)])
  @@index([businessSlug, asOf(sort: Desc)])
  @@map("portfolio_product_lines")
}

model PortfolioUnitEconomics {
  businessSlug  String   @id @map("business_slug")
  orgId         String   @map("org_id") @db.Uuid
  asOf          DateTime @map("as_of") @db.Date
  cac           Decimal  @db.Decimal(18, 2)
  ltv           Decimal  @db.Decimal(18, 2)
  paybackMonths Decimal  @map("payback_months") @db.Decimal(8, 2)
  arpu          Decimal  @db.Decimal(18, 2)
  grossMargin   Decimal  @map("gross_margin") @db.Decimal(5, 4)
  nrr           Decimal  @db.Decimal(5, 4)
  churnMonthly  Decimal  @map("churn_monthly") @db.Decimal(5, 4)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioUnitEconomics", fields: [orgId], references: [id])

  @@index([orgId])
  @@map("portfolio_unit_economics")
}

model PortfolioCohort {
  id           String   @id @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  businessSlug String   @map("business_slug")
  cohortMonth  DateTime @map("cohort_month") @db.Date
  customers    Int
  m0           Decimal  @db.Decimal(5, 4)
  m3           Decimal  @db.Decimal(5, 4)
  m6           Decimal  @db.Decimal(5, 4)
  m12          Decimal  @db.Decimal(5, 4)

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioCohorts", fields: [orgId], references: [id])

  @@unique([businessSlug, cohortMonth])
  @@index([orgId, cohortMonth(sort: Desc)])
  @@index([businessSlug, cohortMonth(sort: Desc)])
  @@map("portfolio_cohorts")
}

model PortfolioHeadcount {
  id             String   @id @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  businessSlug   String   @map("business_slug")
  asOf           DateTime @map("as_of") @db.Date
  function       String
  ftes           Int
  payrollMonthly Decimal  @map("payroll_monthly") @db.Decimal(18, 2)
  openRoles      Int      @map("open_roles")

  business PortfolioBusiness @relation(fields: [businessSlug], references: [slug], onDelete: Cascade)
  org      Organization      @relation("OrgPortfolioHeadcount", fields: [orgId], references: [id])

  @@unique([businessSlug, asOf, function])
  @@index([orgId, asOf(sort: Desc)])
  @@index([businessSlug, asOf(sort: Desc)])
  @@map("portfolio_headcount")
}

// ─── FX rates for multi-currency reporting ─────────────────────────────────
// Stored per (asOf date, base, quote). The FX service picks the latest
// row at-or-before the requested timestamp to convert revenue amounts into
// the configured REPORTING_CURRENCY for cross-portfolio rollups.
//
// Sources are pluggable: ECB / OpenExchangeRates / Wise / a partner's own
// rate-of-record. The `source` column captures provenance for audit.

model FxRate {
  id            String   @id @db.Uuid
  asOf          DateTime @map("as_of") @db.Date
  baseCurrency  String   @map("base_currency") @db.Char(3)
  quoteCurrency String   @map("quote_currency") @db.Char(3)
  // Multiplier: 1 unit of base = `rate` units of quote.
  rate          Decimal  @db.Decimal(18, 8)
  source        String   @default("manual")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([asOf, baseCurrency, quoteCurrency])
  @@index([baseCurrency, quoteCurrency, asOf(sort: Desc)])
  @@map("fx_rates")
}

// ─── Right-to-be-forgotten (GDPR Art. 17 / APP) ────────────────────────────
// One row per data-subject erasure request. The lifecycle worker processes
// PENDING rows: finds every Application carrying the customer's email hash,
// overwrites the encrypted PII columns with zeros, and stamps COMPLETED.
//
// Why we keep the rows after scrub: lender_decisions, revenue_events, and
// audit_logs reference applications. Hard-deleting an application would
// orphan a financial record (we have a 7-year regulatory retention on
// those). Cryptoshred + scrub + audit is the GDPR-aligned compromise: the
// data subject's PII is irrecoverable, the financial trail survives.

enum RtbfRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model RtbfRequest {
  id              String            @id @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  // Hash of the consumer's email. Matches Application.consumerEmailHash so
  // the worker can locate every related row.
  emailHash       Bytes             @map("email_hash")
  status          RtbfRequestStatus @default(PENDING)
  // Free-text reason from the partner / data subject (kept for audit).
  reason          String?
  requestedById   String            @map("requested_by_id") @db.Uuid
  requestedAt     DateTime          @default(now()) @map("requested_at") @db.Timestamptz(6)
  startedAt       DateTime?         @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?         @map("completed_at") @db.Timestamptz(6)
  applicationsScrubbed Int          @default(0) @map("applications_scrubbed")
  // GAP-111: count of credit_enrichments rows scrubbed during processing.
  // Defaults to 0; populated by RtbfService once the cross-table scrub lands.
  creditEnrichmentsScrubbed Int     @default(0) @map("credit_enrichments_scrubbed")
  error           String?

  requestedBy User         @relation("RtbfRequestedBy", fields: [requestedById], references: [id])
  org         Organization @relation("OrgRtbfRequests", fields: [orgId], references: [id])

  @@index([orgId, status, requestedAt(sort: Desc)])
  @@index([status, requestedAt(sort: Desc)])
  @@index([emailHash])
  @@map("rtbf_requests")
}

// ─── Notes + tags (cross-resource) ─────────────────────────────────────────

model Note {
  id           String   @id @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  resourceType String   @map("resource_type") // 'customer' / 'partner' / 'application' / 'lender_decision' / 'case'
  resourceId   String   @map("resource_id")
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  author User         @relation(fields: [authorUserId], references: [id])
  org    Organization @relation("OrgNotes", fields: [orgId], references: [id])

  @@index([orgId, resourceType, resourceId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([authorUserId, createdAt(sort: Desc)])
  @@map("notes")
}

model Tag {
  id          String   @id @db.Uuid
