// EazePay Intelligence — data model
// PostgreSQL 16 + TimescaleDB. UUID v7 PKs. PII columns are AES-256-GCM ciphertext (Bytes)
// + deterministic HMAC hash (Bytes) for lookup. See SECURITY.md for the encryption design.

generator client {
  provider        = "prisma-client-js"
  // Metrics preview enables `prisma.$metrics.json()` / `.prometheus()` for
  // pool + query observability. Surfaced at /metrics for Prometheus scrape.
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum PartnerStatus {
  ACTIVE
  INACTIVE
  CHURNED
}

enum PartnerTier {
  BRONZE
  SILVER
  GOLD
}

enum ApplicationStatus {
  PENDING
  SUBMITTED
  IN_REVIEW
  // GAP-102: EazePay App contract uses OFFERED (when lender offers are
  // presented to consumer) + CONTRACTED (when consumer accepts contract).
  // Both are required for the App platform-sink drain handlers to write
  // the correct status transition. QUARANTINE is for `brand: "direct"`
  // events that have no resolved org until product decides ownership.
  OFFERED
  APPROVED
  CONTRACTED
  DECLINED
  FUNDED
  QUARANTINE
}

enum LenderTier {
  PRIME
  NEAR_PRIME
  SUBPRIME
  CARD_LINKED
}

enum LenderDecisionOutcome {
  APPROVED
  DECLINED
  PENDING
}

enum FundingStatus {
  PENDING
  FUNDED
  FAILED
}

enum UserRole {
  ADMIN
  OPERATOR
  INVESTOR
  VIEWER
}

/// Per-organisation role granted via Membership. Same four levels as the
/// legacy global UserRole, intentionally — same semantics, no retraining.
/// The rename signals "this is org-scoped" not "global".
enum OrgRole {
  ADMIN
  OPERATOR
  INVESTOR
  VIEWER
}

/// Platform-level capability separate from any org membership.
/// STAFF: read-only cross-org. SUPER: write across orgs, impersonate.
/// SUPER satisfies any STAFF check.
enum PlatformRole {
  STAFF
  SUPER
}

enum AggregationPeriod {
  DAILY
  MONTHLY
  YEARLY
}

enum RevenueStream {
  BUZZPAY
  PIXIE
  MICAMP
  // GAP-100: EazePay App platform-sink revenue (medpay / tradepay /
  // coachpay merchant fees, commissions, loan repayment-derived events).
  EAZEPAY_APP
  // GAP-105: HighSale business-unit revenue (snapshot fees, risk-band-
  // assignment commercials).
  HIGHSALE
  // GAP-103 / GAP-104: Aurean AI + Recruitment business-unit revenue.
  AUREAN_AI
  AUREAN_RECRUITMENT
}

enum RevenueEventType {
  ACCRUAL
  FUNDING
  CLAWBACK
  REVERSAL
  PIXIE_MARGIN
  PROCESSING_FEE
  ADJUSTMENT
  // GAP-100: EazePay App platform fee on funded contracts.
  MERCHANT_FEE
  // GAP-100: per-loan commission (repayment-derived).
  COMMISSION
}

enum WebhookSource {
  // BUZZPAY retired (Phase B). Enum value persists until the dedicated
  // Phase C cleanup migration drops it; see docs/cuts/buzzpay-removal.md.
  BUZZPAY
  PIXIE
  MICAMP
  // GAP-100: EazePay App platform-sink. Enables persistence of every
  // App-side application / merchant / commission event.
  EAZEPAY_APP
  // GAP-105: HighSale as a business unit (operational events: inquiry,
  // snapshot lifecycle, risk-band assignment). Distinct from the Plane-2
  // /integration/highsale/snapshots route which writes credit_enrichments.
  HIGHSALE
  // GAP-103: Aurean AI operational events (inference, scoring, revenue).
  AUREAN_AI
  // GAP-104: Aurean Recruitment operational events (placement, commission,
  // pipeline transitions).
  AUREAN_RECRUITMENT
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  FAILED
  REPLAYED
  // GAP-100: drain handler couldn't normalise the event (unmapped brand,
  // unknown partner). Row stays raw + operator-reviewable; the worker
  // stops retrying. Triage via /platform/orgs/:id/eazepay-app/quarantine.
  QUARANTINED
}

// ─── Partner ────────────────────────────────────────────────────────────────

model Partner {
  id                 String        @id @db.Uuid
  // Phase 1 retrofit (2026-05-15): every tenant-scoped table carries
  // org_id. external_id is now unique within an org, not globally.
  orgId              String        @map("org_id") @db.Uuid
  externalId         String        @map("external_id")
  name               String
  industry           String
  onboardingDate     DateTime      @map("onboarding_date") @db.Timestamptz(6)
  status             PartnerStatus @default(ACTIVE)
  tier               PartnerTier   @default(BRONZE)
  contractValue      Decimal       @default(0) @map("contract_value") @db.Decimal(14, 2)
  buzzpayRevSharePct Decimal       @default(0) @map("buzzpay_rev_share_pct") @db.Decimal(5, 4)
  pixieDataPullCost  Decimal       @default(1.00) @map("pixie_data_pull_cost") @db.Decimal(8, 4)
  pixieChargeRate    Decimal       @default(3.00) @map("pixie_charge_rate") @db.Decimal(8, 4)
  pixieMargin        Decimal       @default(2.00) @map("pixie_margin") @db.Decimal(8, 4)
  metadata           Json          @default("{}")
  deletedAt          DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  applications    Application[]
  pixieMetrics    PixieMetric[]
  lenderDecisions LenderDecision[]
  revenueEvents   RevenueEvent[]
  org             Organization     @relation("OrgPartners", fields: [orgId], references: [id])

  @@unique([orgId, externalId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([tier])
  @@index([onboardingDate])
  @@map("partners")
}

// ─── Application ────────────────────────────────────────────────────────────

model Application {
  id                    String @id @db.Uuid
  // Phase 1 retrofit: every tenant table carries org_id. external_application_id
  // is unique per-org now, not globally (a partner's external IDs are unique
  // within their tenant, not across tenants).
  orgId                 String @map("org_id") @db.Uuid
  partnerId             String @map("partner_id") @db.Uuid
  externalApplicationId String @map("external_application_id")

  // PII — ciphertext (Bytes, AES-256-GCM) + deterministic HMAC hash for lookup.
  consumerNameCiphertext  Bytes @map("consumer_name_ciphertext")
  consumerEmailCiphertext Bytes @map("consumer_email_ciphertext")
  consumerEmailHash       Bytes @map("consumer_email_hash")
  consumerPhoneCiphertext Bytes @map("consumer_phone_ciphertext")
  consumerPhoneHash       Bytes @map("consumer_phone_hash")

  // Financial enrichment from Pixie pre-qual.
  creditScore            Int?     @map("credit_score")
  availableCredit        Decimal? @map("available_credit") @db.Decimal(14, 2)
  notedAnnualIncome      Decimal? @map("noted_annual_income") @db.Decimal(14, 2)
  bankStatementsProvided Boolean  @default(false) @map("bank_statements_provided")

  merchantPreapproval       Boolean  @default(false) @map("merchant_preapproval")
  merchantPreapprovalAmount Decimal? @map("merchant_preapproval_amount") @db.Decimal(14, 2)
  consumerPreapproval       Boolean  @default(false) @map("consumer_preapproval")
  consumerPreapprovalAmount Decimal? @map("consumer_preapproval_amount") @db.Decimal(14, 2)

  fundingEstimate   Decimal? @map("funding_estimate") @db.Decimal(14, 2)
  propensityScore   Decimal? @map("propensity_score") @db.Decimal(5, 4)
  openLinesOfCredit Int?     @map("open_lines_of_credit")

  status      ApplicationStatus @default(PENDING)
  submittedAt DateTime?         @map("submitted_at") @db.Timestamptz(6)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner         Partner          @relation(fields: [partnerId], references: [id])
  org             Organization     @relation("OrgApplications", fields: [orgId], references: [id])
  lenderDecisions LenderDecision[]

  @@unique([orgId, externalApplicationId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, status])
  @@index([orgId, consumerEmailHash])
  @@index([partnerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([consumerEmailHash])
  @@index([consumerPhoneHash])
  @@map("applications")
}

// ─── LenderDecision ─────────────────────────────────────────────────────────

model LenderDecision {
  id                String                @id @db.Uuid
  // Phase 1 retrofit: org-scoped. external_decision_id is unique per-org now.
  orgId             String                @map("org_id") @db.Uuid
  // Vendor-supplied decision identifier — the source of truth for idempotency.
  // Nullable for backward compatibility with seed data that predates this column.
  externalDecisionId String?              @map("external_decision_id")
  applicationId     String                @map("application_id") @db.Uuid
  partnerId         String                @map("partner_id") @db.Uuid
  lenderName        String                @map("lender_name")
  lenderTier        LenderTier            @map("lender_tier")
  decision          LenderDecisionOutcome
  decisionTimestamp DateTime              @map("decision_timestamp") @db.Timestamptz(6)
  approvalAmount    Decimal?              @map("approval_amount") @db.Decimal(14, 2)
  apr               Decimal?              @db.Decimal(7, 4)
  term              Int?
  monthlyPayment    Decimal?              @map("monthly_payment") @db.Decimal(14, 2)
  originationFee    Decimal?              @map("origination_fee") @db.Decimal(14, 2)
  fundingStatus     FundingStatus         @default(PENDING) @map("funding_status")
  fundingTimestamp  DateTime?             @map("funding_timestamp") @db.Timestamptz(6)
  fundingAmount     Decimal?              @map("funding_amount") @db.Decimal(14, 2)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  application   Application    @relation(fields: [applicationId], references: [id])
  partner       Partner        @relation(fields: [partnerId], references: [id])
  org           Organization   @relation("OrgLenderDecisions", fields: [orgId], references: [id])
  revenueEvents RevenueEvent[]

  @@unique([orgId, externalDecisionId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, fundingStatus, fundingTimestamp])
  @@index([partnerId, createdAt(sort: Desc)])
  @@index([applicationId])
  @@index([lenderName, decision])
  @@index([fundingStatus, fundingTimestamp])
  @@map("lender_decisions")
}

// ─── RevenueEvent (append-only ledger, Timescale hypertable) ────────────────
// Every dollar shown on a dashboard projects from this ledger. Inserted by
// webhook workers; never updated, never deleted (REVOKE enforced at role level).
// Clawbacks/reversals arrive as new negative-amount rows.

model RevenueEvent {
  id                String           @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Phase 1 retrofit: org-scoped. The (source, idempotencyKey) unique is now
  // per-org so two tenants can independently claim the same idempotency
  // string without colliding.
  orgId             String           @map("org_id") @db.Uuid
  partnerId         String           @map("partner_id") @db.Uuid
  lenderDecisionId  String?          @map("lender_decision_id") @db.Uuid
  pixieMetricPeriod DateTime?        @map("pixie_metric_period") @db.Timestamptz(6)
  source            WebhookSource
  stream            RevenueStream
  eventType         RevenueEventType @map("event_type")
  amount            Decimal          @db.Decimal(14, 2)
  currency          String           @default("USD") @db.Char(3)
  effectiveAt       DateTime         @map("effective_at") @db.Timestamptz(6)
  recordedAt        DateTime         @default(now()) @map("recorded_at") @db.Timestamptz(6)
  idempotencyKey    String           @map("idempotency_key")
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  partner        Partner         @relation(fields: [partnerId], references: [id])
  lenderDecision LenderDecision? @relation(fields: [lenderDecisionId], references: [id])
  org            Organization    @relation("OrgRevenueEvents", fields: [orgId], references: [id])

  @@id([effectiveAt, partnerId, idempotencyKey])
  // Per-org idempotency. Different tenants share the same idempotency-key
  // namespace safely.
  @@unique([orgId, source, idempotencyKey], name: "revenue_events_org_source_idemp_key")
  @@index([orgId, effectiveAt(sort: Desc)])
  @@index([partnerId, effectiveAt(sort: Desc)])
  @@index([stream, effectiveAt(sort: Desc)])
  @@index([eventType, effectiveAt(sort: Desc)])
  @@index([lenderDecisionId])
  @@map("revenue_events")
}

// ─── WebhookEvent (audit + replay protection) ───────────────────────────────
// Every inbound webhook lands here first — durable record before queueing.
// `idempotencyKey` is unique; replays return the original processing result.

model WebhookEvent {
  id              String                  @id @db.Uuid
  // Phase 1 retrofit: org-scoped. The (source, idempotencyKey) unique is
  // now per-org. Backfill maps via WebhookCredential's active row per
  // source; new rows must thread orgId from signature verification.
  orgId           String                  @map("org_id") @db.Uuid
  source          WebhookSource
  eventType       String                  @map("event_type")
  idempotencyKey  String                  @map("idempotency_key")
  signatureValid  Boolean                 @map("signature_valid")
  status          WebhookProcessingStatus @default(RECEIVED)
  payload         Json
  processingError String?                 @map("processing_error")
  receivedAt      DateTime                @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt     DateTime?               @map("processed_at") @db.Timestamptz(6)

  org Organization @relation("OrgWebhookEvents", fields: [orgId], references: [id])

  @@unique([orgId, source, idempotencyKey])
  @@index([orgId, receivedAt(sort: Desc)])
  @@index([source, status, receivedAt(sort: Desc)])
  @@index([receivedAt(sort: Desc)])
  @@map("webhook_events")
}

// ─── PixieMetric (Timescale hypertable) ─────────────────────────────────────

model PixieMetric {
  id                  String            @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String            @map("org_id") @db.Uuid
  partnerId           String            @map("partner_id") @db.Uuid
  period              AggregationPeriod
  periodStart         DateTime          @map("period_start") @db.Timestamptz(6)
  periodEnd           DateTime          @map("period_end") @db.Timestamptz(6)
  dataPullsThisPeriod Int               @map("data_pulls_this_period")
  dataPullsCumulative Int               @map("data_pulls_cumulative")
  costPerPull         Decimal           @map("cost_per_pull") @db.Decimal(8, 4)
  chargePerPull       Decimal           @map("charge_per_pull") @db.Decimal(8, 4)
  profitPerPull       Decimal           @map("profit_per_pull") @db.Decimal(8, 4)
  totalRevenue        Decimal           @map("total_revenue") @db.Decimal(14, 2)
  volumeThreshold     Int               @map("volume_threshold")
  volumeAchieved      Int               @map("volume_achieved")
  discountApplied     Decimal           @default(0) @map("discount_applied") @db.Decimal(14, 2)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  partner Partner @relation(fields: [partnerId], references: [id])
  org     Organization @relation("OrgPixieMetrics", fields: [orgId], references: [id])

  @@id([periodStart, partnerId, period])
  @@index([orgId, periodStart(sort: Desc)])
  @@index([partnerId, periodStart(sort: Desc)])
  @@map("pixie_metrics")
}

// ─── RevenueAggregation (Timescale hypertable) ──────────────────────────────

model RevenueAggregation {
  id                   String            @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String            @map("org_id") @db.Uuid
  period               AggregationPeriod
  periodStart          DateTime          @map("period_start") @db.Timestamptz(6)
  periodEnd            DateTime          @map("period_end") @db.Timestamptz(6)
  totalApplications    Int               @map("total_applications")
  approvedApplications Int               @map("approved_applications")
  fundedApplications   Int               @map("funded_applications")
  buzzpayRevshareTotal Decimal           @map("buzzpay_revshare_total") @db.Decimal(14, 2)
  processingFeesTotal  Decimal           @map("processing_fees_total") @db.Decimal(14, 2)
  pixieMarginTotal     Decimal           @map("pixie_margin_total") @db.Decimal(14, 2)
  pixieDataPullsTotal  Int               @map("pixie_data_pulls_total")
  activePartnerCount   Int               @map("active_partner_count")
  newPartnerCount      Int               @map("new_partner_count")
  totalRevenue         Decimal           @map("total_revenue") @db.Decimal(14, 2)
  approvalRate         Decimal           @map("approval_rate") @db.Decimal(5, 4)
  fundingRate          Decimal           @map("funding_rate") @db.Decimal(5, 4)
  avgDealSize          Decimal           @map("avg_deal_size") @db.Decimal(14, 2)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  org Organization @relation("OrgRevenueAggregations", fields: [orgId], references: [id])

  @@id([periodStart, period])
  @@index([orgId, periodStart(sort: Desc)])
  @@index([period, periodStart(sort: Desc)])
  @@map("revenue_aggregations")
}

// ─── Organization (tenant root) ─────────────────────────────────────────────
// Each organisation is a logical tenant. Every domain row in the system
// (with documented exceptions in PLATFORM_V2.md and the multi-tenancy
// blast-radius doc) carries an `orgId` foreign key to one of these rows.
//
// The `slug` is a lowercase kebab identifier used as the URL path component
// (`/api/v1/o/:orgSlug/...`). It is immutable after creation except via
// platform staff intervention.
//
// `dataRegion` is a forward-compatibility hook for Phase 8 data-residency
// controls. Today every deployment runs in one region; the column lets us
// route storage + compute when multi-region lands without another migration.

model Organization {
  id               String   @id @db.Uuid
  slug             String   @unique
  name             String
  // Two-letter ISO region (e.g. "au"). Phase 8 reads this to pin compute +
  // storage per-org. Today: informational only.
  dataRegion       String   @default("au") @map("data_region") @db.VarChar(8)
  stripeCustomerId String?  @map("stripe_customer_id")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships         Membership[]
  invitations         UserInvitation[]      @relation("OrgInvitations")
  apiTokens           ApiToken[]            @relation("OrgApiTokens")
  auditLogs           AuditLog[]            @relation("OrgAuditLogs")
  webhookCredentials  WebhookCredential[]   @relation("OrgWebhookCredentials")
  encryptionKeys      TenantEncryptionKey[] @relation("OrgEncryptionKeys")
  creditEnrichments   CreditEnrichment[]    @relation("OrgCreditEnrichments")
  // Phase 1 retrofit (2026-05-15) — reverse relations for every tenant-
  // scoped table that now carries org_id. Mirrors the migration
  // 20260515120000_phase1_tenant_table_retrofit.
  partners            Partner[]             @relation("OrgPartners")
  applications        Application[]         @relation("OrgApplications")
  lenderDecisions     LenderDecision[]      @relation("OrgLenderDecisions")
  revenueEvents       RevenueEvent[]        @relation("OrgRevenueEvents")
  webhookEvents       WebhookEvent[]        @relation("OrgWebhookEvents")
  pixieMetrics        PixieMetric[]         @relation("OrgPixieMetrics")
  revenueAggregations RevenueAggregation[]  @relation("OrgRevenueAggregations")
  outboxEvents        OutboxEvent[]         @relation("OrgOutboxEvents")
  exports             Export[]              @relation("OrgExports")
  webhookSubscriptions WebhookSubscription[] @relation("OrgWebhookSubscriptions")
  webhookDeliveries   WebhookDelivery[]     @relation("OrgWebhookDeliveries")
  refreshTokens       RefreshToken[]        @relation("OrgRefreshTokens")
  notificationChannels NotificationChannel[] @relation("OrgNotificationChannels")
  alertRules          AlertRule[]           @relation("OrgAlertRules")
  alerts              Alert[]               @relation("OrgAlerts")
  notes               Note[]                @relation("OrgNotes")
  tags                Tag[]                 @relation("OrgTags")
  tagAssignments      TagAssignment[]       @relation("OrgTagAssignments")
  savedViews          SavedView[]           @relation("OrgSavedViews")
  scheduledReports    ScheduledReport[]     @relation("OrgScheduledReports")
  reportRuns          ReportRun[]           @relation("OrgReportRuns")
  cases               Case[]                @relation("OrgCases")
  rtbfRequests        RtbfRequest[]         @relation("OrgRtbfRequests")
  portfolioVerticals  PortfolioVertical[]   @relation("OrgPortfolioVerticals")
  portfolioBusinesses PortfolioBusiness[]   @relation("OrgPortfolioBusinesses")
  portfolioFinancialPeriods PortfolioFinancialPeriod[] @relation("OrgPortfolioFinancialPeriods")
  portfolioRevenueChannels  PortfolioRevenueChannel[]  @relation("OrgPortfolioRevenueChannels")
  portfolioProductLines     PortfolioProductLine[]     @relation("OrgPortfolioProductLines")
  portfolioUnitEconomics    PortfolioUnitEconomics[]   @relation("OrgPortfolioUnitEconomics")
  portfolioCohorts          PortfolioCohort[]          @relation("OrgPortfolioCohorts")
  portfolioHeadcount        PortfolioHeadcount[]       @relation("OrgPortfolioHeadcount")

  @@map("organizations")
}

/// User membership in an Organization, with a per-org role.
/// One user can be in many orgs. Replaces the legacy global User.role
/// for authorization decisions; User.role is retained during the
/// migration window for backward compatibility and removed at end of
/// Phase 1.

model Membership {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      OrgRole
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId, role])
  @@map("memberships")
}

// ─── User / Auth ────────────────────────────────────────────────────────────

model User {
  id           String    @id @db.Uuid
  email        String    @unique
  // Optional: users created via OAuth (e.g. Google) carry no local password.
  // Local accounts still get a bcrypt hash on accept-invitation / set-password.
  passwordHash String?   @map("password_hash")
  // Legacy global role. Authorization migrates to Membership.role during
  // Phase 1.2; this column is retained for backward compat in the
  // migration window and removed at end of Phase 1. New code must read
  // role from the active Membership, not from here.
  role         UserRole  @default(VIEWER)
  // Platform-level capability that crosses org boundaries. Brodie + ops staff.
  // null = no platform privileges. STAFF = read-only cross-org. SUPER =
  // unrestricted. Independent from any Membership.
  platformRole PlatformRole? @map("platform_role")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  mfaSecret    String?   @map("mfa_secret")
  // Federated identity. Stable Google `sub` claim — emails can change, sub
  // cannot. Unique so two local accounts can't claim the same Google identity.
  googleSub    String?   @unique @map("google_sub")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships          Membership[]
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  apiTokens            ApiToken[]
  exports               Export[]
  webhookSubscriptions WebhookSubscription[]
  notes                Note[]
  tagAssignments       TagAssignment[]
  savedViews           SavedView[]
  scheduledReports     ScheduledReport[]
  casesOpened          Case[]                @relation("CaseOpenedBy")
  casesAssigned        Case[]                @relation("CaseAssignee")
  rtbfRequests         RtbfRequest[]         @relation("RtbfRequestedBy")
  invitationsIssued    UserInvitation[]      @relation("InviteIssuedBy")

  @@index([platformRole])
  @@map("users")
}

/// Email-based invitation flow. An admin issues a UserInvitation; the
/// invitee receives a one-time link to set their own password. We store
/// only the SHA-256 of the token — the plaintext lives in the email and
/// is unrecoverable from a compromised DB.
model UserInvitation {
  id           String    @id @db.Uuid
  email        String
  // OrgRole going forward. Legacy rows pre-Phase-1.2 retain their
  // historic UserRole value (same enum values, different name) — see
  // migration 20260508150000 for the in-place type swap.
  role         OrgRole
  tokenHash    String    @unique @map("token_hash")
  invitedById  String    @map("invited_by_id") @db.Uuid
  // Org the invitation grants access to. Resolved at issue time from
  // the issuer's active org context. Required: an invitation cannot
  // exist without an org to belong to.
  orgId        String    @map("org_id") @db.Uuid
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt   DateTime? @map("accepted_at") @db.Timestamptz(6)
  acceptedById String?   @map("accepted_by_id") @db.Uuid
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  invitedBy User         @relation("InviteIssuedBy", fields: [invitedById], references: [id])
  org       Organization @relation("OrgInvitations", fields: [orgId], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@index([orgId])
  @@map("user_invitations")
}

model RefreshToken {
  id         String    @id @db.Uuid
  // Phase 1 retrofit: org-scoped. Identifies which org the session is acting
  // within. Membership revocation flips access on tokens belonging to that
  // (userId, orgId). For multi-org users, each org has its own family.
  orgId      String    @map("org_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  familyId   String    @map("family_id") @db.Uuid
  // Phase 4c: session identifier (===familyId today; can diverge once
  // "trust this device" lands). Used by /auth/sessions enumerate +
  // revoke, and embedded in access JWTs as `sid` so a revoked session
  // immediately invalidates outstanding access tokens (Redis deny-list).
  sessionId  String    @map("session_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation("OrgRefreshTokens", fields: [orgId], references: [id])

  @@index([orgId, userId, revokedAt])
  @@index([userId])
  @@index([familyId])
  @@index([userId, sessionId, revokedAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id           String   @id @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  // Org the action took place within. Nullable: platform-level events
  // (org creation, FX rate updates, system lifecycle jobs) have no org.
  // Tenant audit views filter by orgId; platform-staff views can query
  // across orgs (with their own audit trail). See ADR-001 §9.
  orgId        String?  @map("org_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json     @default("{}")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User?         @relation(fields: [userId], references: [id])
  org  Organization? @relation("OrgAuditLogs", fields: [orgId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Tier-1 enterprise enums ────────────────────────────────────────────────

enum ApiTokenScope {
  READ
  WRITE
  ADMIN
}

enum ExportType {
  CUSTOMERS
  APPLICATIONS
  LENDER_DECISIONS
  REVENUE_LEDGER
  PARTNERS
  AUDIT_LOG
}

enum ExportFormat {
  CSV
  JSON
  XLSX
}

enum ExportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  EXPIRED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  ABANDONED
}

enum AlertSeverity {
  INFO
  WARN
  CRITICAL
}

enum AlertState {
  OPEN
  ACKNOWLEDGED
  SNOOZED
  RESOLVED
}

enum ChannelKind {
  EMAIL
