{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "DATABASE_REPLICA_URL",
    "DATABASE_LONG_URL",
    "REDIS_URL",
    "NODE_ENV",
    "LOG_LEVEL",
    "PII_ENCRYPTION_KEY",
    "PII_HASH_SECRET",
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_WS_TICKET_SECRET",
    "JWT_INVESTOR_SCOPE_SECRET",
    "CSRF_SIGNING_SECRET",
    "OAUTH_STATE_SECRET",
    "MFA_STEP_UP_SECRET",
    "METRICS_BEARER_TOKEN",
    "API_TOKEN_HASH_SECRET",
    "BUZZPAY_WEBHOOK_SECRET",
    "PIXIE_WEBHOOK_SECRET",
    "MICAMP_WEBHOOK_SECRET",
    "EAZEPAY_APP_WEBHOOK_SECRET",
    "HIGHSALE_WEBHOOK_SECRET",
    "AUREAN_AI_WEBHOOK_SECRET",
    "AUREAN_RECRUITMENT_WEBHOOK_SECRET",
    "KMS_DEV_SECRET",
    "AWS_KMS_KEY_ARN",
    "GOOGLE_OAUTH_CLIENT_ID",
    "GOOGLE_OAUTH_CLIENT_SECRET",
    "GOOGLE_OAUTH_REDIRECT_URI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": []
    },
    "lint": { "outputs": [] },
    "test": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["node_modules/.prisma/**"]
    },
    "dev": { "cache": false, "persistent": true }
  }
}
