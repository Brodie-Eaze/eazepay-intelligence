# EazePay Intelligence — environment template.
# Copy to .env and fill values. Generated from apps/api/src/config/env.ts schema.

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ─── Database ───────────────────────────────────────────────────────────────
# Production: bound the per-instance connection budget. Prisma's default is to
# open as many connections as it likes, which exhausts Postgres's max_connections
# at scale. Set connection_limit to (Postgres max_connections / replica count) − a
# safety margin. 10 is a sane default for a single-replica dev environment;
# scale up for prod alongside your pgbouncer / pool_timeout strategy.
DATABASE_URL=postgresql://eazepay:eazepay@localhost:5432/eazepay_intel?schema=public&connection_limit=10&pool_timeout=20

# Optional read replica (writer/reader split). Analytics + dashboard reads
# route here when set; falls back to primary on connection failure.
# DATABASE_REPLICA_URL=postgresql://eazepay:eazepay@localhost:5433/eazepay_intel?schema=public&connection_limit=20&pool_timeout=20

# Optional long-running-worker URL. Connects as `eazepay_worker_long` role
# (statement_timeout=5min) for exports / backfills / monthly aggregations.
# Falls back to DATABASE_URL when unset. Use a separate connection pool —
# long jobs are exactly the ones you don't want sharing capacity with the
# API request path.
# DATABASE_LONG_URL=postgresql://eazepay_worker_long:secret@localhost:5432/eazepay_intel?schema=public&connection_limit=4&pool_timeout=300

# Behind PgBouncer in transaction mode? Append `&pgbouncer=true` to all of the
# *_URL vars above. Prisma 5.x respects this and disables prepared statements
# (PgBouncer's transaction pooling can't safely share them across clients).

# Slow-query threshold (ms). Anything ≥ this is logged at WARN level.
DATABASE_SLOW_QUERY_LOG_MS=500

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-32-byte-min-access-secret-________
JWT_REFRESH_SECRET=change-me-32-byte-min-refresh-secret-_______
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── PII encryption (AES-256-GCM, base64 32 bytes) ──────────────────────────
PII_ENCRYPTION_KEY=
PII_HASH_SECRET=change-me-deterministic-hash-pepper-_____

# ─── Webhook signing ────────────────────────────────────────────────────────
BUZZPAY_WEBHOOK_SECRET=change-me-buzzpay-shared-secret-_______
PIXIE_WEBHOOK_SECRET=change-me-pixie-shared-secret-________
MICAMP_WEBHOOK_SECRET=change-me-micamp-shared-secret-_______

# ─── CORS allowlist (comma-separated) ───────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── Rate limit (per-tier; see docs/COMPUTE_LIMITS.md) ──────────────────────
# Anonymous / unauthenticated requests, keyed on req.ip
RATE_LIMIT_PER_IP_PER_MIN=100
# Authenticated cookie/PAT, keyed on auth.userId — global default
RATE_LIMIT_PER_USER_PER_MIN=1000
# /ingestion/* endpoints (PAT-driven ETL, batch backfills)
RATE_LIMIT_INGESTION_PER_MIN=6000
# Vendor webhook ingress per source IP (sized for retry storms)
RATE_LIMIT_WEBHOOK_PER_MIN=10000

# ─── Body limits (bytes) ────────────────────────────────────────────────────
BODY_LIMIT_DEFAULT_BYTES=1048576
BODY_LIMIT_BULK_BYTES=8388608
BODY_LIMIT_WEBHOOK_BYTES=2097152

# ─── Worker concurrency (BullMQ) ────────────────────────────────────────────
# Bound CPU + DB connections per worker process.
WORKER_WEBHOOK_CONCURRENCY=10
WORKER_DELIVERY_CONCURRENCY=20
WORKER_OUTBOX_BATCH=100

# ─── Pixie pricing ──────────────────────────────────────────────────────────
PIXIE_VOLUME_BREAKPOINT=25000
PIXIE_COST_PER_PULL=1.00
PIXIE_CHARGE_PER_PULL=3.00

# ─── Frontend (apps/web) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
