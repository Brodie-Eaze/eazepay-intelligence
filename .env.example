# EazePay Intelligence — environment template.
# Copy to .env and fill values. Generated from apps/api/src/config/env.ts schema.

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
# API listen port. Web runs on :3011 (apps/web/package.json dev).
PORT=3010

# ─── Database ───────────────────────────────────────────────────────────────
# Production: bound the per-instance connection budget. Prisma's default is to
# open as many connections as it likes, which exhausts Postgres's max_connections
# at scale. Set connection_limit to (Postgres max_connections / replica count) − a
# safety margin. 10 is a sane default for a single-replica dev environment;
# scale up for prod alongside your pgbouncer / pool_timeout strategy.
DATABASE_URL=postgresql://eazepay:eazepay@localhost:5432/eazepay_intel?schema=public&connection_limit=10&pool_timeout=20

# Optional read replica (writer/reader split). Analytics + dashboard reads
# route here when set; falls back to primary on connection failure.
# DATABASE_REPLICA_URL=postgresql://eazepay:eazepay@localhost:5433/eazepay_intel?schema=public&connection_limit=20&pool_timeout=20

# Optional long-running-worker URL. Connects as `eazepay_worker_long` role
# (statement_timeout=5min) for exports / backfills / monthly aggregations.
# Falls back to DATABASE_URL when unset. Use a separate connection pool —
# long jobs are exactly the ones you don't want sharing capacity with the
# API request path.
# DATABASE_LONG_URL=postgresql://eazepay_worker_long:secret@localhost:5432/eazepay_intel?schema=public&connection_limit=4&pool_timeout=300

# Behind PgBouncer in transaction mode? Append `&pgbouncer=true` to all of the
# *_URL vars above. Prisma 5.x respects this and disables prepared statements
# (PgBouncer's transaction pooling can't safely share them across clients).

# Slow-query threshold (ms). Anything ≥ this is logged at WARN level.
DATABASE_SLOW_QUERY_LOG_MS=500

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<generate-via-openssl-rand-base64-48>
JWT_REFRESH_SECRET=<generate-via-openssl-rand-base64-48>
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── PII encryption (AES-256-GCM, base64 32 bytes) ──────────────────────────
# REQUIRED. Generate a fresh value per environment:
#   openssl rand -base64 32
# This key encrypts every PII column at rest (consumer name / email / phone /
# DOB / address on `applications` + `credit_enrichments`). Losing it = data
# loss; rotating it = re-encrypting the whole corpus. Treat as crown-jewels.
PII_ENCRYPTION_KEY=<generate-via-openssl-rand-base64-32>
# HMAC pepper for deterministic email/phone/DOB hashes. Rotating it breaks
# every analytical join. Generate once per environment and never rotate.
PII_HASH_SECRET=<generate-via-openssl-rand-base64-32>

# ─── Webhook signing ────────────────────────────────────────────────────────
# Each upstream system signs payloads with HMAC-SHA-256 using the shared
# secret. Generate each one via: openssl rand -base64 32.
PIXIE_WEBHOOK_SECRET=<generate-via-openssl-rand-base64-32>
MICAMP_WEBHOOK_SECRET=<generate-via-openssl-rand-base64-32>
# Shared with EazePay App's outbound dispatcher (variable name there:
# EAZEPAY_INTELLIGENCE_SINK_SECRET — same value, different home).
# Generate: openssl rand -base64 64
# See docs/integration/eazepay-app-contract.md.
EAZEPAY_APP_WEBHOOK_SECRET=<generate-via-openssl-rand-base64-32>
# Shared with HighSale (EZ Check) outbound dispatcher. One snapshot per
# application across medpay/tradepay/coachpay. Generate: openssl rand -base64 32.
# See docs/architecture/data-warehouse-overview.md § Plane 2.
HIGHSALE_WEBHOOK_SECRET=<generate-via-openssl-rand-base64-32>

# ─── CORS allowlist (comma-separated) ───────────────────────────────────────
# Web dev server defaults to :3011 (apps/web/package.json `dev` script).
CORS_ORIGINS=http://localhost:3011

# ─── Rate limit (per-tier; see docs/COMPUTE_LIMITS.md) ──────────────────────
# Anonymous / unauthenticated requests, keyed on req.ip
RATE_LIMIT_PER_IP_PER_MIN=100
# Authenticated cookie/PAT, keyed on auth.userId — global default
RATE_LIMIT_PER_USER_PER_MIN=1000
# /ingestion/* endpoints (PAT-driven ETL, batch backfills)
RATE_LIMIT_INGESTION_PER_MIN=6000
# Vendor webhook ingress per source IP (sized for retry storms)
RATE_LIMIT_WEBHOOK_PER_MIN=10000

# ─── Body limits (bytes) ────────────────────────────────────────────────────
BODY_LIMIT_DEFAULT_BYTES=1048576
BODY_LIMIT_BULK_BYTES=8388608
BODY_LIMIT_WEBHOOK_BYTES=2097152

# ─── Worker concurrency (BullMQ) ────────────────────────────────────────────
# Bound CPU + DB connections per worker process.
WORKER_WEBHOOK_CONCURRENCY=10
WORKER_DELIVERY_CONCURRENCY=20
WORKER_OUTBOX_BATCH=100

# ─── Multi-currency ─────────────────────────────────────────────────────────
# DEFAULT_CURRENCY: ISO-4217 currency tag applied to a RevenueEvent when
# the inbound webhook payload doesn't specify one (legacy vendors).
# REPORTING_CURRENCY: rollup currency for analytics — every cross-portfolio
# aggregation converts into this via FxService.
DEFAULT_CURRENCY=USD
REPORTING_CURRENCY=USD

# ─── Pixie pricing ──────────────────────────────────────────────────────────
PIXIE_VOLUME_BREAKPOINT=25000
PIXIE_COST_PER_PULL=1.00
PIXIE_CHARGE_PER_PULL=3.00

# ─── OpenTelemetry (distributed tracing) ────────────────────────────────────
# When OTEL_ENABLED=true, the api + every worker initialises an OpenTelemetry
# SDK that auto-instruments HTTP, Postgres, Redis, and BullMQ. Spans export
# via OTLP/HTTP to the configured endpoint — Datadog, Honeycomb, Grafana
# Tempo, NewRelic, Jaeger all accept this format.
#
# Default off in dev/test (zero overhead). Turn on in staging + prod.
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.internal:4318
# OTEL_EXPORTER_OTLP_HEADERS=api-key=xxx,team=eazepay
# OTEL_SERVICE_NAME=eazepay-intelligence-api

# ─── App URL (used for invitation + OAuth callback links) ──────────────────
# Public-facing host the browser uses, NOT the API host. Embedded into
# emails sent by Resend; the OAuth state machine round-trips through it.
APP_URL=http://localhost:3011

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Optional in dev: when RESEND_API_KEY is unset, emails print to the API
# console instead of being sent. Production deployments MUST set both.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=EazePay Intelligence <noreply@eazepay.local>
INVITATION_TTL_HOURS=168

# ─── OAuth (Google) ─────────────────────────────────────────────────────────
# When all three of CLIENT_ID/CLIENT_SECRET/REDIRECT_URI are set, the
# /auth/oauth/google/* surfaces activate and the login page surfaces a
# Google button. Leave unset to remain password-only.
#
# Set the redirect URI in the Google Cloud console to EXACTLY this value:
#   <API_HOST>/api/v1/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback
#
# Comma-separated email domains permitted to sign in via OAuth. Empty =
# any verified Google account whose email matches an existing User row.
# Recommended for prod: lock to your work domain so a stray Gmail account
# can't claim an invited seat.
# GOOGLE_OAUTH_ALLOWED_DOMAINS=eazepay.com,amalafinance.com.au

# ─── Frontend (apps/web) ────────────────────────────────────────────────────
# Points at the API (PORT above). Web itself runs on 3011 (apps/web pkg).
NEXT_PUBLIC_API_URL=http://localhost:3010
NEXT_PUBLIC_WS_URL=ws://localhost:3010
